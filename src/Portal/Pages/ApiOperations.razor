@page "/api-operations"
@attribute [Authorize]
@inject IT4ApiClient ApiClient
@using System.Text
@using Newtonsoft.Json
@using T4.ApiClient.Exceptions
@using T4.ApiClient.Services
@using T4.AxClient.Model

<PageTitle>T4 API Operations</PageTitle>

<h1>T4 API Operations</h1>

<p>Use these actions to call the T4 <code>Users</code> API endpoints with your Entra token.</p>

<div class="mb-4">
    <label for="requestUserInvitePayload">RequestUserInvite payload</label>
    <textarea id="requestUserInvitePayload" class="form-control" rows="4" @bind="requestUserInvitePayload"></textarea>
    <button class="btn btn-primary mt-2" @onclick='() => CallOperationAsync("RequestUserInvite", requestUserInvitePayload)'>Call RequestUserInvite</button>
    <pre>@requestUserInviteResponse</pre>
</div>

<div class="mb-4">
    <label for="registerUserPayload">RegisterUser payload</label>
    <textarea id="registerUserPayload" class="form-control" rows="4" @bind="registerUserPayload"></textarea>
    <button class="btn btn-primary mt-2" @onclick='() => CallOperationAsync("RegisterUser", registerUserPayload)'>Call RegisterUser</button>
    <pre>@registerUserResponse</pre>
</div>

<div class="mb-4">
    <label for="getUserPayload">GetUser payload</label>
    <textarea id="getUserPayload" class="form-control" rows="4" @bind="getUserPayload"></textarea>
    <button class="btn btn-primary mt-2" @onclick='() => CallOperationAsync("GetUser", getUserPayload)'>Call GetUser</button>
    <pre>@getUserResponse</pre>
</div>

<div class="mb-4">
    <label for="makeCustomCallPayload">MakeCustomCall payload</label>
    <textarea id="makeCustomCallPayload" class="form-control" rows="4" @bind="makeCustomCallPayload"></textarea>
    <button class="btn btn-primary mt-2" @onclick='() => CallOperationAsync("MakeCustomCall", makeCustomCallPayload)'>Call MakeCustomCall</button>
    <pre>@makeCustomCallResponse</pre>
</div>

@code {







    private string requestUserInvitePayload = """
    {
      "email": "user@example.com",
      "name": "Sample User",
      "message": "Welcome!"
    }
    """;

    private string registerUserPayload = """
    {
      "inviteCode": "replace-with-invite-code",
      "nameOrDescription": "Sample User"
    }
    """;

    private string getUserPayload = "{}";

    private string makeCustomCallPayload = """
    {
      "customCallName": "replace-with-custom-call-name",
      "payload": {}
    }
    """;

    private string requestUserInviteResponse = string.Empty;
    private string registerUserResponse = string.Empty;
    private string getUserResponse = string.Empty;
    private string makeCustomCallResponse = string.Empty;

    private async Task CallOperationAsync(string operation, string payload)
    {
        using var request = new HttpRequestMessage(HttpMethod.Post, $"Users/{operation}")
        {
            Content = new StringContent(payload, Encoding.UTF8, "application/json")
        };

        try
        {
            var formattedResult = await DoOperation(operation, payload);
            SetOperationResponse(operation, formattedResult);
        }
        catch (ApiRequestNotSucceededException ex)
        {
            SetOperationResponse(operation, $"Request failed: {ex.ErrorFeedbackContract.Message}");
        }
        catch (Exception ex)
        {
            SetOperationResponse(operation, $"Request failed: {ex}");
        }
    }

    private async Task<string> DoOperation(string operation, string payload)
    {
        switch (operation)
        {
            case "RequestUserInvite":
                {
                    var deserializeObject = Newtonsoft.Json.JsonConvert.DeserializeObject<PortalSvcRequestUserInviteRequest>(payload)!;
                    var response = await ApiClient.RequestUserInvite(CancellationToken.None, deserializeObject);

                    return Newtonsoft.Json.JsonConvert.SerializeObject(response, Formatting.Indented);
                }
            case "RegisterUser":
                {
                    var deserializeObject = Newtonsoft.Json.JsonConvert.DeserializeObject<PortalSvcRegisterUserRequest>(payload)!;
                    var response = await ApiClient.RegisterUser(CancellationToken.None, deserializeObject);

                    return Newtonsoft.Json.JsonConvert.SerializeObject(response, Formatting.Indented);
                }
            case "GetUser":
                {
                    var deserializeObject = Newtonsoft.Json.JsonConvert.DeserializeObject<PortalSvcGetUserRequest>(payload)!;
                    var response = await ApiClient.GetUser(CancellationToken.None, deserializeObject);

                    return Newtonsoft.Json.JsonConvert.SerializeObject(response, Formatting.Indented);
                }
            case "MakeCustomCall":
                {
                    var deserializeObject = Newtonsoft.Json.JsonConvert.DeserializeObject<PortalSvcMakeCustomCallRequest>(payload)!;
                    var response = await ApiClient.MakeCustomCall(CancellationToken.None, deserializeObject);

                    return Newtonsoft.Json.JsonConvert.SerializeObject(response, Formatting.Indented);
                }
        }

        throw new ArgumentException($"'{operation}' is not an operation name!", nameof(operation));
    }

    private void SetOperationResponse(string operation, string result)
    {
        switch (operation)
        {
            case "RequestUserInvite":
                requestUserInviteResponse = result;
                break;
            case "RegisterUser":
                registerUserResponse = result;
                break;
            case "GetUser":
                getUserResponse = result;
                break;
            case "MakeCustomCall":
                makeCustomCallResponse = result;
                break;
        }
    }
}
